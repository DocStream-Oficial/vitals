# ── Demo mode (Fase 8A) ──────────────────────────────────────────────────────
# Set VITALS_DEMO=1 to run Vitals with a deterministic synthetic dataset
# (tests/fixtures/demo_dataset.json, generated by scripts/gen_demo_data.py) —
# no OAuth, no tokens, no real credentials needed below. Sync/auth/ingest/source
# endpoints all short-circuit to a harmless {"status":"demo"} response, and
# journal/labs/cycle writes go to a throwaway temp directory. Leave unset (or
# 0/false) for normal operation with your real data sources.
# VITALS_DEMO=1

# Google OAuth credentials (from Google Cloud Console)
CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
CLIENT_SECRET=YOUR_CLIENT_SECRET

# Redirect URI — must match what's registered in Google Cloud Console
# Dev:  http://localhost:8700/auth/callback
# Prod: https://your-box.your-tailnet.ts.net/auth/callback
REDIRECT_URI=http://localhost:8700/auth/callback

# User profile (used for Coach and body-age calculation)
BIRTHDATE=YYYY-MM-DD
WAIST_CM=80
SEX=M
PREFER_PLATFORM=AUTO

# Scheduler: hour (24h) for daily sync (default 9)
SYNC_HOUR=9

# Google token expiry nag (token-nag-fix). If your Google OAuth app is
# Published (In production), Google's refresh_token never expires by age —
# leave this at 0 (default) so the dashboard never shows a fake "reconnect"
# countdown; auth_state() only warns on a REAL failure (invalid_grant).
# Set to 7 only if your OAuth app is still in Testing mode in Google Cloud
# Console, where Google really does cap refresh tokens at ~7 days.
#   0 = app Published / permanent token (default)
#   7 = app in Testing mode (Google's real ~7-day cap)
GOOGLE_TOKEN_EXPIRY_DAYS=0

# Path/command for the Claude CLI, used by the conversational Coach tab (shells
# out to `claude` via subprocess — no API key required if you already have the
# CLI installed, e.g. via OpenClaw). Auto-detected with shutil.which("claude")
# if unset; override only if the CLI isn't on PATH or you want a specific
# binary. If the CLI isn't available at all, the Coach degrades gracefully to
# a deterministic rules-based fallback narrative — this is optional.
# CLAUDE_CLI=/usr/local/bin/claude

# ── Coach LLM backend (swappable, Fase P0 F3) ───────────────────────────────
# COACH_BACKEND selects how app/llm.py talks to an LLM for the Coach chat,
# the headline, and the weekly/monthly reports. Two options:
#   claude_cli    (default) — shells out to the Claude CLI, same as CLAUDE_CLI
#                 above. No API key needed.
#   openai_compat — POSTs to an OpenAI-compatible /chat/completions endpoint
#                 (stdlib urllib only, no new pip dependency). Use this to
#                 run the Coach fully offline/self-hosted against a local
#                 model server (Ollama, LM Studio, llama.cpp server, etc.).
# An unrecognized value falls back to claude_cli (logged as a warning).
COACH_BACKEND=claude_cli

# Base URL of the OpenAI-compatible endpoint (only used when
# COACH_BACKEND=openai_compat). Examples:
#   Ollama (default port, OpenAI-compat API):   http://localhost:11434/v1
#   LM Studio (default local server):            http://localhost:1234/v1
COACH_API_BASE=http://localhost:11434/v1

# Model name to request from the endpoint above. Examples:
#   Ollama:     llama3.1  (must be `ollama pull`ed first)
#   LM Studio:  whatever model name you loaded in the LM Studio server tab
COACH_MODEL=llama3.1

# API key for the endpoint above, sent as "Authorization: Bearer <key>".
# Leave empty for local servers that don't require auth (Ollama, LM Studio
# by default) — the header is only sent if this is non-empty.
COACH_API_KEY=

# Oura OAuth credentials (BYO — bring your own).
# 1. Create an app at https://cloud.ouraring.com/oauth/applications
# 2. Set its redirect URI to match REDIRECT_URI above (same /auth/callback Google uses;
#    the callback routes to the active source automatically).
# 3. Paste the client_id/client_secret it gives you below.
# Only needed if you choose "Oura" as your data source in onboarding/Más.
OURA_CLIENT_ID=YOUR_OURA_CLIENT_ID
OURA_CLIENT_SECRET=YOUR_OURA_CLIENT_SECRET

# WHOOP OAuth credentials (BYO — bring your own).
# 1. Create an app at https://developer.whoop.com
# 2. Set its redirect URI to match REDIRECT_URI above (same /auth/callback Google/Oura
#    use; the callback routes to the active source automatically).
# 3. Paste the client_id/client_secret it gives you below.
# Only needed if you choose "WHOOP" as your data source in onboarding/Más.
WHOOP_CLIENT_ID=YOUR_WHOOP_CLIENT_ID
WHOOP_CLIENT_SECRET=YOUR_WHOOP_CLIENT_SECRET

# Shared secret for Apple HealthKit PUSH ingestion (native iOS app -> POST
# /api/ingest and /api/ecg). MANDATORY as of Fase 8C: if left empty here,
# Vitals auto-generates one on first boot and persists it to
# data/ingest_token.json — check the "More" tab in the app (or the QR code
# there) to copy the active token into the iOS app. Every /api/ingest and
# /api/ecg request must send this exact value as the X-Vitals-Token header,
# or it's rejected with 401 — there is no "no auth" mode anymore.
# To set your own instead of relying on auto-generation:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_TOKEN=

# Dashboard auth (opt-in, RECOMMENDED). Empty (default) = OFF, the dashboard is
# open to anyone who can reach the host. Set a value to require login (cookie
# or "Authorization: Bearer <token>") for the web dashboard — see SECURITY.md.
DASHBOARD_TOKEN=
